# Nexus AI Agent — Environment Variables
# Copy this file to .env and fill in your values

# ══════════════════════════════════════
# REQUIRED: Pick one LLM provider
# ══════════════════════════════════════

# OpenRouter (recommended — unified API for Claude/GPT/Gemini/DeepSeek)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OR Anthropic directly
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OR OpenAI directly
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════
# Telegram Bot (required for Telegram integration)
# Get your token from @BotFather
# ══════════════════════════════════════
NEXUS_TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyzabcdefghijklmnop

# ══════════════════════════════════════
# Optional: Model Configuration
# ══════════════════════════════════════

# Default model for agent (used for conversation)
NEXUS_DEFAULT_MODEL=anthropic/claude-3-haiku

# Compression model (used for context compression — must be cheap model)
NEXUS_COMPRESSION_MODEL=openai/gpt-4o-mini

# Temperature (0.0 = deterministic, 1.0 = very random)
NEXUS_TEMPERATURE=0.7

# Max context tokens
NEXUS_MAX_CONTEXT_TOKENS=100000

# ══════════════════════════════════════
# Optional: Paths
# ══════════════════════════════════════

# Skills directory (default: ~/.nexus/skills)
# NEXUS_SKILLS_DIR=~/.nexus/skills

# Memory directory (default: ~/.nexus/memory)
# NEXUS_MEMORY_DIR=~/.nexus/memory

# ══════════════════════════════════════
# Optional: Features
# ══════════════════════════════════════

# Enable dreaming (default: true)
# NEXUS_DREAMING_ENABLED=true

# Max skill generations per day (default: 3)
# NEXUS_MAX_SKILL_GEN=3
